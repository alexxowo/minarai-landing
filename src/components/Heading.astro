---
import HeaderTitle from "./atoms/HeaderTitle.astro";
import hero_image from "../assets/images/CABECERA (1).png";
// import hero_image from "../assets/images/IMG_1208.JPG";

const heroImages = [
    hero_image.src,
    // Add more images here for future rotation
];
---

<section
    class="relative w-full min-h-[calc(100vh-80px)] flex flex-col md:flex-row items-center justify-between px-6 md:px-12 pt-12 md:pt-0"
>
    <div
        class="flex-1 flex flex-col items-center justify-center z-20 w-full text-center mt-8 md:mt-0"
    >
        <!-- <span
            class="text-gray-500 font-light uppercase tracking-[0.2em] text-xs md:text-base mb-1 md:mb-[-10px] md:ml-1"
        >
            Academia de karate-do
        </span> -->

        <h1
            class="bg-golden-rod-500/80 text-black text-5xl md:text-9xl font-bebas tracking-wider font-bold leading-[0.9] mb-4 md:mb-2 px-6 pt-3 pb-1 md:px-10 md:pt-6 md:pb-2 shadow-lg"
        >
            DOJO MINARAI
        </h1>

        <span
            class="bg-barbados-cherry-500/80 text-white font-raleway font-light text-lg md:text-3xl italic mb-8 md:mb-12 px-6 py-2 md:px-8 md:py-3 shadow-lg"
        >
        Academia de karate-do
            <!-- El aprendizaje <br class="block md:hidden" /> mediante la observación -->
        </span>

        <!-- <button class="bg-golden-rod-500 text-black font-bebas tracking-wide text-lg md:text-xl px-8 py-3 rounded-md uppercase hover:bg-golden-rod-600 transition-colors shadow-lg cursor-default">
            Inicia Sesión
        </button> -->
    </div>

    <!-- Right Image Placeholder -->
    <div class="absolute inset-0 w-full h-full z-0">
        <img
            id="hero-image"
            src={heroImages[0]}
            alt="Karateka Minarai"
            class=" w-full h-full object-cover transition-opacity duration-1000 blur-[2px]"
        />
    </div>

    <!-- Gradient overlay: white on the left (under text), transparent in the middle, dark/black on the right -->
    <div class="absolute inset-0 z-10 pointer-events-none gradient-overlay">
    </div>

    <!-- Scroll Down Indicator -->
    <a
        href="#about"
        class="absolute bottom-0 -translate-y-1/2 left-1/2 -translate-x-1/2 z-20 w-12 h-12 rounded-full bg-white shadow-lg border border-gray-100 flex items-center justify-center text-black hover:text-amber-600 hover:scale-110 active:scale-95 transition-all duration-300 cursor-pointer group"
        aria-label="Ir a sección Sobre Nosotros"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2.5"
            stroke="currentColor"
            class="w-6 h-6 transition-transform duration-300 group-hover:translate-y-0.5"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 8.25l-7.5 7.5-7.5-7.5"
            />
        </svg>
    </a>
</section>

<style>
    .gradient-overlay {
        filter: blur(40px);
    }
    @media (min-width: 768px) {
        .gradient-overlay {
            filter: blur(60px);
        }
    }
</style>


