---
import jkr_logo from "../assets/images/JKRV.svg"
import soke_yasuhiro_konishi from "../assets/images/Yasuhiro.png"
---

<section class="h-screen max-w-7xl mx-auto px-4 md:px-12 py-20 flex flex-col md:flex-row items-center gap-12 bg-white">
    <!-- Left Image -->
    <div class="flex-1 relative w-full">
        <img 
            src={soke_yasuhiro_konishi.src} 
            alt="Soke Yasuhiro Konishi" 
            class="w-full h-auto object-cover rounded-lg shadow-lg grayscale relative z-10"
        />
        
        <!-- Vertical Kanjis with Parallax -->
        <div class="absolute top-0 -left-2 md:-left-12 lg:-left-20 h-full flex items-center justify-center z-0 pointer-events-none parallax-container">
            <span 
                class="kanji-parallax text-gray-100 font-black text-4xl md:text-6xl lg:text-8xl tracking-widest whitespace-nowrap select-none" 
                style="writing-mode: vertical-rl; text-orientation: upright;"
            >
                日本空手道良武会
            </span>
        </div>
    </div>

    <!-- Right Content -->
    <div class="flex-1 flex flex-col gap-8 items-center md:items-start text-center md:text-left">
        <div class="w-full max-w-[20rem] md:max-w-[20rem] lg:max-w-[30rem] h-auto mx-auto self-center">
             <img 
                src={jkr_logo.src} 
                alt="Japan Karate-Do Ryobu-Kai Logo" 
                class="w-full h-auto"
            />
        </div>
        
        <div class="flex flex-col gap-6 text-lg font-light leading-relaxed text-justify">
            <p>
                Formamos parte de la Organización Internacional Japan Karate-Do Ryobu-Kai, fundada en 1933 por el Soke Yasuhiro Konishi, creador del estilo Shindo Jinen Ryu Karate Jutsu y representada en Venezuela por el Sensei Martín Materano.
            </p>
            <p>
                Hoy, Ryobu-Kai tiene presencia en más de 30 países, y mantiene vivo un legado técnico y filosófico que nos conecta directamente con Japón.
            </p>
        </div>
    </div>
</section>

<script>
    const parallaxContainers = document.querySelectorAll('.parallax-container');
    
    const onScroll = () => {
        parallaxContainers.forEach(container => {
            const el = container.querySelector('.kanji-parallax') as HTMLElement;
            if (!el) return;
            
            const rect = container.getBoundingClientRect();
            const centerY = window.innerHeight / 2;
            const elementCenterY = rect.top + rect.height / 2;
            
            // Distance from the center of the viewport
            const diff = elementCenterY - centerY;
            
            // Parallax speed factor
            const speed = 0.15;
            el.style.transform = `translateY(${-diff * speed}px)`;
        });
    };
    
    window.addEventListener('scroll', onScroll, { passive: true });
    // Initial call
    onScroll();
</script>
